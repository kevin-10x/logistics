# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/afrilogistics

# SMS Provider (Africa's Talking / Termii / MSG91)
SMS_API_KEY=your_sms_api_key
SMS_BASE_URL=https://api.africastalking.com
SMS_ENABLED=true

# Mobile Money
MOMO_API_KEY=your_momo_api_key
MOMO_BASE_URL=https://proxy.momoapi.mtn.com
MOMO_ENVIRONMENT=sandbox

# JWT Auth
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Maps / Geocoding
GOOGLE_MAPS_API_KEY=your_google_maps_key
MAPBOX_TOKEN=your_mapbox_token

# Weather API
WEATHER_API_KEY=your_openweather_key

# Redis (for caching & real-time)
REDIS_URL=redis://localhost:6379

# Firebase (push notifications)
FIREBASE_PROJECT_ID=your_firebase_project
FIREBASE_PRIVATE_KEY=your_firebase_key

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002
